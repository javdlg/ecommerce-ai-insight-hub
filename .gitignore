# ==========================================
# Entornos Virtuales y Python
# ==========================================
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
.env

# ==========================================
# Credenciales y Seguridad
# ==========================================
# NUNCA subir la Wallet de Oracle DB ni llaves privadas
*.pem
*.key
Wallet_*.zip
wallet/
cwallet.sso
ewallet.p12
keystore.jks
truststore.jks
sqlnet.ora
tnsnames.ora

# ==========================================
# Datos y Bases de Datos Locales
# ==========================================
# Ignorar el contenido de las carpetas de datos, pero mantener la estructura
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Directorio de la base de datos vectorial local (ChromaDB/FAISS)
chroma_db/
vector_store/
*.sqlite3
*.db

# ==========================================
# Terraform (Infraestructura como Código)
# ==========================================
# Directorio local de Terraform
.terraform/
# Archivos de estado (¡contienen información sensible de la nube!)
*.tfstate
*.tfstate.backup
# Archivos de variables sobreescritas
*.tfvars
*.tfvars.json
# Archivos de bloqueo de dependencias
.terraform.lock.hcl

# ==========================================
# IDEs y Herramientas (Antigravity, VSCode, etc.)
# ==========================================
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# ==========================================
# Jupyter Notebooks (Si haces pruebas locales)
# ==========================================
.ipynb_checkpoints/

# Journal
JOURNAL.md